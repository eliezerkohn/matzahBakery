{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": [ "dotnet" ],
      "variables": {
        "NIXPACKS_DOTNET_VERSION": "8"
      }
    }
  },
  "deploy": {
    "startCommand": "dotnet MatzahBakery.Web.dll",
    "restartPolicyType": "ON_FAILURE"
  }
}